#!/usr/bin/env python3
"""
Mirror a plugin from the Claude skills repo to the skills-openai (Codex) repo.

Usage:
    bin/mirror_to_codex <plugin-name>
    bin/mirror_to_codex --all

What it does:
- Reads plugins/<name>/skills/<name>/SKILL.md from the Claude repo
- Strips Claude-only frontmatter fields: version, argument-hint
  (Codex's validator rejects these; move intent to metadata: if needed)
- Writes the result to ../skills-openai/plugins/<name>/SKILL.md
- Also updates .agents/plugins/marketplace.json in skills-openai

Codex structure (flat, SKILL.md at plugin root):
  skills-openai/plugins/<name>/SKILL.md

Claude structure (nested):
  skills/plugins/<name>/skills/<name>/SKILL.md
"""

import json
import re
import shutil
import sys
from pathlib import Path

# Fields stripped from frontmatter when mirroring to Codex
# (Codex allows: name, description, license, allowed-tools, metadata)
CODEX_INCOMPATIBLE = {"version", "argument-hint"}

CLAUDE_REPO = Path(__file__).parent.parent.parent.parent.parent  # skills/
CODEX_REPO = CLAUDE_REPO.parent / "skills-openai"
CODEX_MARKETPLACE = CODEX_REPO / ".agents" / "plugins" / "marketplace.json"


def strip_frontmatter_fields(content: str, strip_keys: set) -> tuple[str, list[str]]:
    """Remove specified keys from YAML frontmatter. Returns (new_content, stripped_keys)."""
    if not content.startswith("---"):
        return content, []

    match = re.match(r"^(---\n)(.*?)(\n---\n?)(.*)", content, re.DOTALL)
    if not match:
        return content, []

    open_fence, fm_text, close_fence, body = match.groups()

    stripped = []
    new_fm_lines = []
    skip_until_key = False

    for line in fm_text.splitlines():
        # Detect a top-level key line (not indented)
        key_match = re.match(r"^([a-zA-Z_-]+)\s*:", line)
        if key_match:
            key = key_match.group(1)
            if key in strip_keys:
                skip_until_key = True
                stripped.append(key)
                continue
            else:
                skip_until_key = False
        elif skip_until_key and (line.startswith(" ") or line.startswith("\t")):
            # continuation of a multi-line value we're skipping
            continue
        else:
            skip_until_key = False

        new_fm_lines.append(line)

    new_fm = "\n".join(new_fm_lines)
    return f"{open_fence}{new_fm}{close_fence}{body}", stripped


def mirror_plugin(name: str) -> bool:
    src_skill = CLAUDE_REPO / "plugins" / name / "skills" / name / "SKILL.md"
    if not src_skill.exists():
        print(f"  [FAIL] Source not found: {src_skill}")
        return False

    dst_dir = CODEX_REPO / "plugins" / name
    dst_dir.mkdir(parents=True, exist_ok=True)
    dst_skill = dst_dir / "SKILL.md"

    content = src_skill.read_text()
    new_content, stripped = strip_frontmatter_fields(content, CODEX_INCOMPATIBLE)

    dst_skill.write_text(new_content)

    if stripped:
        print(f"  [OK] {name}  (stripped Claude-only fields: {', '.join(stripped)})")
    else:
        print(f"  [OK] {name}")

    # Also copy any references/ or scripts/ subdirectories
    src_skill_dir = src_skill.parent
    for sub in ("references", "scripts", "assets"):
        src_sub = src_skill_dir / sub
        if src_sub.exists():
            dst_sub = dst_dir / sub
            if dst_sub.exists():
                shutil.rmtree(dst_sub)
            shutil.copytree(src_sub, dst_sub)
            print(f"       + mirrored {sub}/")

    return True


def main():
    if not CODEX_REPO.exists():
        print(f"Error: Codex repo not found at {CODEX_REPO}")
        print("Create it first: mkdir -p ~/dev/skills-openai")
        sys.exit(1)

    if len(sys.argv) == 2 and sys.argv[1] == "--all":
        plugins_dir = CLAUDE_REPO / "plugins"
        names = sorted(p.name for p in plugins_dir.iterdir() if p.is_dir())
        if not names:
            print("No plugins found.")
            sys.exit(1)
    elif len(sys.argv) == 2:
        names = [sys.argv[1]]
    else:
        print("Usage: bin/mirror_to_codex <plugin-name>")
        print("       bin/mirror_to_codex --all")
        sys.exit(1)

    print(f"Mirroring to: {CODEX_REPO}")
    print()

    success = 0
    for name in names:
        if mirror_plugin(name):
            success += 1

    print()
    print(f"Mirrored {success}/{len(names)} plugins.")
    if success < len(names):
        sys.exit(1)


if __name__ == "__main__":
    main()
